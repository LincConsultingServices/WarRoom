# ──────────────────────────────────────────────────────────────────────────────
# War Room Frontend (Next.js) — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials — NEVER commit ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.cer
*-key.json
*serviceaccount*.json
service-account*.json
*service*account*.json
warroom-nr-*.json
*credentials*.json
firebase-adminsdk-*.json
gcp-*.json
id_rsa*
id_ed25519*
*.secret

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
node_modules/
/.pnp
.pnp.js
.pnp.*

# ── Next.js / build output ────────────────────────────────────────────────────
/.next/
.next/
/out/
/build
/dist

# ── Testing / coverage ────────────────────────────────────────────────────────
/coverage

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Databases & dumps ─────────────────────────────────────────────────────────
*.sql
*.sqlite
*.sqlite3
*.db
*.dump

# ── Local helper / one-off scripts (not needed to run the app) ────────────────
check-key.js
list-available-models.js
test-gemini-*.js

# ── Generated script output (not source code) ─────────────────────────────────
scripts/compression-results.json

# ── Logs & debug ──────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Temp / backup / cache ─────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
.cache/

# ── Internal docs (keep README) ───────────────────────────────────────────────
*.md
!README.md
.claudeignore

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Python venv (local tooling, if any) ───────────────────────────────────────
.venv/
__pycache__/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ── AI assistant metadata ─────────────────────────────────────────────────────
.claude/
.cursor/
.aider*

# NOTE: cloudbuild-frontend.yaml is intentionally TRACKED (Cloud Build reads it).

# ── Generated assets (optional — uncomment to stop tracking heavy generated media)
# public/assets/images/textures/*.webp
# public/investors/*/portrait.webp
