# ============================================
# War Room — Frontend (Next.js) Configuration
# ============================================
# Architecture: Firebase Authentication (client SDK) + Go backend on Cloud Run.
# The frontend has NO database, NextAuth, or server secrets anymore — the browser
# only holds Firebase's PUBLIC client identifiers and the backend API URL.

# --------------------------------------------
# Backend API (Go service)
# --------------------------------------------
# Local dev:  http://localhost:8080/api
# Production:  your Cloud Run URL, e.g.
#   https://warroom-backend-xxxxxxxxxxxx.us-central1.run.app/api
NEXT_PUBLIC_API_URL="http://localhost:8080/api"

# --------------------------------------------
# Firebase Authentication (client SDK)
# --------------------------------------------
# These are PUBLIC values (safe to ship to the browser by Firebase design). The Go
# backend independently verifies every ID token with the Admin SDK, so they grant
# no privileged access. Copy them from:
#   Firebase Console → Project settings → General → Your apps → SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="warroom-nr.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="warroom-nr"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
